---
// Fundations
import DocsLayout from "@/layouts/DocsLayout.astro";
import RightSidebarLayout from "@/layouts/RightSidebarLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Header from "@/components/fundations/containers/Header.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Icons
import ChevronRight from "@/components/fundations/icons/ChevronRight.astro";
import ArrowDownright from "@/components/fundations/icons/ArrowDownright.astro";
const { frontmatter, previous, next, headings = [] } = Astro.props;
// Scripts
import TocAnimationScript from "@/components/fundations/scripts/TocAnimationScript.astro";
// Breadcrumbs
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: frontmatter.page, href: "#" },
];
---

<DocsLayout>
  <section>
    <RightSidebarLayout>
      <div slot="main">
        <Header title={frontmatter.page} innerClass="gap-24 lg:gap-32">
          <div class="order-first">
            <nav aria-label="Breadcrumb">
              <ol
                class="flex items-center text-xs gap-1 text-base-500 dark:text-base-300"
              >
                {
                  breadcrumbs.map((item, index) => (
                    <>
                      <li>
                        {index < breadcrumbs.length - 1 ? (
                          <a
                            href={item.href}
                            class="text-xs font-medium hover:text-accent-500 text-base-900 dark:text-white"
                          >
                            {item.label}
                          </a>
                        ) : (
                          <span class="text-xs font-medium text-accent-500">
                            {item.label}
                          </span>
                        )}
                      </li>
                      {index < breadcrumbs.length - 1 && (
                        <li class="text-base-400">
                          <ChevronRight size="xs" />
                        </li>
                      )}
                    </>
                  ))
                }
              </ol>
            </nav>
            <Text
              tag="p"
              variant="textXS"
              class="flex items-center mt-1 font-mono font-medium text-base-400 gap-2"
            >
              <ArrowDownright size="sm" />
              Last updated <time
                datetime={new Date(frontmatter.pubDate).toLocaleDateString(
                  "en-US",
                  {
                    year: "numeric",
                    month: "long",
                    day: "2-digit",
                  }
                )}
                >{
                  new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "2-digit",
                  })
                }</time
              >
            </Text>
          </div>
        </Header>
        <section>
          <Wrapper variant="prose" class="px-8 py-8"><slot /></Wrapper>
        </section>
      </div>
      <div slot="rightAside">
        <Text
          tag="h4"
          variant="textSM"
          class="ml-4 text text-base-900 dark:text-white">On this page</Text
        >
        <div class="flex flex-col h-full mt-4">
          {
            headings
              .filter((h) => h.depth === 2 || h.depth === 3)
              .map((heading) => (
                <a
                  href={`#${heading.slug ?? heading.text.toLowerCase().replace(/\s+/g, "-")}`}
                  class="block py-1 text-xs border-l-2 border-transparent select-none hover:text-accent-600 dark:hover:text-accent-400 text-base-500 dark:text-base-400  transition-all duration-200 toc-link"
                  style={`padding-left: ${heading.depth === 3 ? "1.8rem" : "1rem"}`}
                  data-heading-id={heading.slug ?? heading.text.toLowerCase().replace(/\s+/g, "-")}
                  data-heading-depth={heading.depth}
                >
                  {heading.text}
                </a>
              ))
          }
        </div>
      </div>
    </RightSidebarLayout>
    <nav
      aria-label="Infopage pagination"
      class="w-full border-t grid grid-cols-1 md:grid-cols-2 divide-y divide-base-200 dark:divide-base-800 lg:divide-y-0 lg:divide-x border-base-200 dark:border-base-800"
    >
      <div class="w-full">
        {
          previous && (
            <a
              href={`/legal/${previous.id}`}
              class="flex flex-col w-full p-8 gap-12 group hover:bg-base-50 dark:hover:bg-white/1 duration-200"
            >
              <span class="font-mono text-xs font-medium tracking-wide uppercase text-base-500 dark:text-base-400">
                Previous
              </span>
              <div>
                <div class="text-sm font-medium truncate text-base-900 dark:text-white group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
                  {previous.data.title || previous.data.page}
                </div>
                <div class="text-xs capitalize text-base-500 dark:text-base-400">
                  {previous.data.category?.replace("-", " ")}
                </div>
              </div>
            </a>
          )
        }
      </div>
      <div class="w-full">
        {
          next && (
            <a
              href={`/legal/${next.id}`}
              class="flex flex-col justify-end w-full p-8 gap-12 group hover:bg-base-50 dark:hover:bg-white/1 duration-200"
            >
              <span class="font-mono text-xs font-medium tracking-wide uppercase text-base-500 dark:text-base-400">
                Next
              </span>
              <div>
                <div class="text-sm font-medium truncate text-base-900 dark:text-white group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
                  {next.data.title || next.data.page}
                </div>
                <div class="text-xs capitalize text-base-500 dark:text-base-400">
                  {next.data.category?.replace("-", " ")}
                </div>
              </div>
            </a>
          )
        }
      </div>
    </nav>
  </section>
</DocsLayout>
<TocAnimationScript />
