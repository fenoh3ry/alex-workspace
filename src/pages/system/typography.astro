---
// Assets
import Dots from "@/components/assets/Dots.astro";
import Header from "@/components/fundations/containers/Header.astro";
// Fundations
import DocsLayout from "@/layouts/DocsLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
---

<DocsLayout>
  <Header
    title="Typography"
    description="Geist - Geist Mono"
    innerClass="pt-24"
  >
  </Header>
  <div
    class="flex flex-col p-8 font-medium text-base-900 dark:text-white space-y-8"
  >
    <Text tag="p" variant="textXS"> Text XS </Text>
    <Text tag="p" variant="textSM"> Text SM </Text>
    <Text tag="p" variant="textBase"> Text Base </Text>
    <Text tag="p" variant="textLG"> Text LG </Text>
    <Text tag="p" variant="textXL"> Text XL </Text>
    <Text tag="p" variant="displaySM" class="font-display upercase">
      Display SM
    </Text>
    <Text tag="p" variant="displayMD" class="font-display upercase">
      Display MD
    </Text>
    <Text tag="p" variant="displayLG" class="font-display upercase">
      Display LG
    </Text>
    <Text tag="p" variant="displayXL" class="font-display upercase">
      Display XL
    </Text>
    <Text tag="p" variant="display2XL" class="font-display upercase">
      Display 2XL
    </Text>
    <Text tag="p" variant="display3XL" class="font-display upercase">
      Display 3XL
    </Text>
    <Text tag="p" variant="display4XL" class="font-display upercase">
      Display 4XL
    </Text>
    <Text tag="p" variant="display5XL" class="font-display upercase">
      Display 5XL
    </Text>
    <Text tag="p" variant="display6XL" class="font-display upercase">
      Display 6XL
    </Text>
  </div>
</DocsLayout>
