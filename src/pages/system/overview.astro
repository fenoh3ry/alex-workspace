---
// Assets
import Header from "@/components/fundations/containers/Header.astro";
// Fundations
import DocsLayout from "@/layouts/DocsLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
// Data array
const pageData = [
  {
    categoryTitle: "Static",
    links: [
      {
        sectionTitle: "Landing Pages",
        links: [
          {
            title: "Home",
            url: "/",
          },
          { title: "404", url: "/404" },
        ],
      },
      {
        sectionTitle: "Forms ",
        links: [
          {
            title: "Sign in",
            url: "/sign-in",
          },
          {
            title: "Sign up",
            url: "/sign-up",
          },
        ],
      },
      {
        sectionTitle: "System Pages",
        links: [
          { title: "Links", url: "/system/links" },
          { title: "Buttons", url: "/system/buttons" },
          { title: "Colors", url: "/system/colors" },
          { title: "Alerts", url: "/system/alerts" },
          { title: "Badges", url: "/system/badges" },
          { title: "Typography", url: "/system/typography" },
          {
            title: "License",
            url: "https://lexingtonthemes.com/legal/license",
          },
          {
            title: "Docs",
            url: "https://lexingtonthemes.com/documentation",
          },
        ],
      },
    ],
  },
  {
    categoryTitle: "Content Collection",
    links: [
      {
        sectionTitle: "Documentation",
        links: [
          {
            title: "Details",
            url: "/docs/getting-started/introduction",
          },
        ],
      },
      {
        sectionTitle: "Blog",
        links: [
          {
            title: "Home",
            url: "/blog",
          },
          {
            title: "Post",
            url: "/blog/posts/1",
          },
          { title: "Tag index", url: "/blog/tags" },
          {
            title: "Tag Category",
            url: "/blog/tags/astro",
          },
          { title: "RSS", url: "/rss.xml" },
        ],
      },
      {
        sectionTitle: "Integrations",
        links: [
          {
            title: "Home",
            url: "/integrations/",
          },
          {
            title: "Details",
            url: "/integrations/1",
          },
        ],
      },
      {
        sectionTitle: "Changelog",
        links: [
          {
            title: "Home",
            url: "/changelog/",
          },
          {
            title: "Details",
            url: "/changelog/command-palette",
          },
        ],
      },
      {
        sectionTitle: "Team",
        links: [
          {
            title: "Home",
            url: "/team/",
          },
          {
            title: "Details",
            url: "/team/jordan-wells",
          },
        ],
      },
      {
        sectionTitle: "Legal",
        links: [
          {
            title: "Details",
            url: "/legal/licensing",
          },
        
        ],
      },
    ],
  },
];
---

<DocsLayout>
  <section>
    <Header title="Overview" innerClass="pt-24" />
    <div class="flex flex-col p-8 gap-12">
      {
        pageData.map((category) => (
          <>
            <div>
              <Text
                tag="h2"
                variant="textLG"
                class="font-medium  text-base-900 dark:text-white"
              >
                {category.categoryTitle}
              </Text>
              <div class="mt-4 gap-y-8 gap-x-4 grid grid-cols-2 lg:grid-cols-5 md:grid-cols-3 ">
                {category.links.map((section) => (
                  <div>
                    <Text
                      tag="h3"
                      variant="textBase"
                      class="text-base-900 dark:text-white"
                    >
                      {section.sectionTitle}
                    </Text>
                    <div class="flex flex-col mt-4 text-sm gap-1 text-base-500">
                      {section.links.map((link) => (
                        <a class="hover:text-accent-500" href={link.url}>
                          {link.title}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </>
        ))
      }
    </div>
  </section>
</DocsLayout>
