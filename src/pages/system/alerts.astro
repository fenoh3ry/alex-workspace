---
// Assets
import Header from "@/components/fundations/containers/Header.astro";
// Fundations
import DocsLayout from "@/layouts/DocsLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Alert from "@/components/fundations/elements/Alert.astro";
// Only import if you want to show custom icon override example
// import CustomIcon from "@/components/icons/CustomIcon.astro";
---

<DocsLayout>
  <Header title="Alerts" innerClass="pt-24" />
  <div class="p-8 space-y-8">
    <!-- Basic Variants -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Basic Alert Variants
      </h2>
      <div class="mt-2 space-y-4">
        <Alert
          variant="warning"
          title="Attention needed"
          description="This is a warning alert with default icon and styling."
        />
        <Alert
          variant="error"
          title="Error occurred"
          description="Something went wrong. Please try again or contact support."
        />
        <Alert
          variant="info"
          title="Information"
          description="Here is some helpful information for you to consider."
        />
        <Alert
          variant="success"
          title="Success!"
          description="Your action was completed successfully."
        />
        <Alert
          variant="neutral"
          title="General notice"
          description="This is a neutral alert for general information."
        />
      </div>
    </section>
    <!-- Dismissible Alerts -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Dismissible Alerts
      </h2>
      <div class="mt-2 space-y-4">
        <Alert
          variant="warning"
          title="Dismissible warning"
          description="You can close this alert by clicking the X button."
          dismissible={true}
        />
        <Alert
          variant="info"
          title="Temporary notice"
          description="This alert can be dismissed when you're done reading."
          dismissible={true}
        />
      </div>
    </section>
    <!-- Alerts with Lists -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Alerts with Lists
      </h2>
      <div class="mt-2 space-y-4">
        <Alert
          variant="error"
          title="Multiple issues found"
          description="Please address the following issues:"
          list={[
            "Password must be at least 8 characters long",
            "Email address is already in use",
            "Phone number format is invalid",
          ]}
        />
        <Alert
          variant="info"
          title="Requirements checklist"
          description="Make sure you have completed all of these steps:"
          list={[
            "Create your account",
            "Verify your email address",
            "Set up two-factor authentication",
            "Complete your profile",
          ]}
        />
      </div>
    </section>
    <!-- Alerts with Links -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Alerts with Links
      </h2>
      <div class="mt-2 space-y-4">
        <Alert
          variant="neutral"
          title="Need more help?"
          description="Check out these helpful resources to get started."
          links={[
            { href: "/docs/getting-started", label: "Getting Started" },
            { href: "/docs/help/faq", label: "FAQ" },
            { href: "/docs/support", label: "Contact Support" },
          ]}
        />
        <Alert
          variant="warning"
          title="Action required"
          description="Your subscription will expire soon."
          links={[
            { href: "/billing/renew", label: "Renew Subscription" },
            { href: "/billing/plans", label: "View Plans" },
          ]}
        />
      </div>
    </section>
    <!-- Complex Alerts -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Complex Alerts
      </h2>
      <div class="mt-2 space-y-4">
        <Alert
          variant="error"
          title="System maintenance"
          description="We're currently performing scheduled maintenance. Some features may be temporarily unavailable."
          list={[
            "File uploads are disabled",
            "Email notifications are delayed",
            "Real-time sync is paused",
          ]}
          links={[
            { href: "/status", label: "Check Status Page" },
            { href: "/support", label: "Contact Support" },
          ]}
          dismissible={true}
        />
        <Alert
          variant="success"
          title="Welcome to the beta!"
          description="Thanks for joining our beta program. Here's what you need to know:"
          list={[
            "New features are released weekly",
            "Your feedback helps shape the product",
            "Beta access includes all premium features",
          ]}
          links={[
            { href: "/beta/feedback", label: "Give Feedback" },
            { href: "/beta/changelog", label: "View Changelog" },
            { href: "/beta/community", label: "Join Community" },
          ]}
        />
      </div>
    </section>
    <!-- Minimal Alerts -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Minimal Alerts
      </h2>
      <div class="mt-2 space-y-4">
        <Alert variant="success" title="Saved!" />
        <Alert variant="error" title="Connection failed" />
        <Alert
          variant="info"
          description="This alert only has a description, no title."
        />
      </div>
    </section>
    <!-- No Icon Example -->
    <section>
      <h2 class="text-base font-meidum text-base-900 dark:text-white">
        Without Icons
      </h2>
      <div class="mt-2 space-y-4">
        <Alert
          variant="warning"
          title="Simple warning"
          description="This alert doesn't show an icon."
          icon={null}
        />
        <Alert
          variant="info"
          title="Text-only alert"
          description="Sometimes you just want text without visual clutter."
          icon={null}
        />
      </div>
    </section>
  </div>
</DocsLayout>
