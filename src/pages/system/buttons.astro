---
import Header from "@/components/fundations/containers/Header.astro";
import DocsLayout from "@/layouts/DocsLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Plus from "@/components/fundations/icons/Plus.astro";

function formatLabel(text: string) {
  return text
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}
---

<DocsLayout>
  <section>
    <Header title="Buttons" innerClass="pt-24" />
    <div class="p-8 flex flex-col gap-y-24">
      {
        [
          "default",
          "accent",
          "muted",
          "info",
          "success",
          "warning",
          "danger",
          "outline",
          "outline-accent",
          "outline-info",
          "outline-success",
          "outline-warning",
          "outline-danger",
        ].map((variant) => (
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
              <Text
                tag="p"
                variant="textXS"
                class="font-medium uppercase text-base-900 dark:text-white"
              >
                {formatLabel(variant)} text
              </Text>
              <div class="flex flex-wrap mt-2 gap-1 gap-y-4">
                {["mini", "xxs", "xs", "sm", "base", "md", "lg", "xl"].map(
                  (size) => (
                    <Button size={size} variant={variant} class="w-fit">
                      {`${formatLabel(variant)} ${size.toUpperCase()}`}
                    </Button>
                  )
                )}
              </div>
            </div>
            <div>
              <Text
                tag="p"
                variant="textXS"
                class="font-medium uppercase text-base-900 dark:text-white"
              >
                Icon
              </Text>
              <div class="flex flex-wrap mt-2 gap-1">
                {["mini", "xxs", "xs", "sm", "base", "md", "lg", "xl"].map(
                  (size) => (
                    <Button href="#_" size={size} variant={variant} iconOnly>
                      <Plus slot="icon" size="sm" />
                    </Button>
                  )
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</DocsLayout>
