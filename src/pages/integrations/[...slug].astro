---
import { getCollection, render } from "astro:content";
import IntegrationsLayout from "@/layouts/IntegrationsLayout.astro";

// Step 1: getStaticPaths
export async function getStaticPaths() {
  const allIntegrations = await getCollection("integrations");

  const sorted = [...allIntegrations].sort((a, b) =>
    a.id.localeCompare(b.id)
  );

  return sorted.map((page) => ({
    params: { slug: page.id },
    props: { slug: page.id },
    trailingSlash: false,
  }));
}

// Step 2: Load content + find previous/next
const { slug } = Astro.props;

const allIntegrations = await getCollection("integrations");
const sorted = [...allIntegrations].sort((a, b) => a.id.localeCompare(b.id));

const index = sorted.findIndex((item) => item.id === slug);
const page = sorted[index];
const previous = sorted[index - 1] || null;
const next = sorted[index + 1] || null;

const { Content } = await render(page);
---

<IntegrationsLayout frontmatter={page.data} previous={previous} next={next}>
  <Content />
</IntegrationsLayout>
