---
import { getCollection, render } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
export async function getStaticPaths() {
  const blogEntries = await getCollection("posts");
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { pageSlug: entry.id },
  }));
}
const { pageSlug } = Astro.props;

const allPosts = await getCollection("posts");
const validPosts = allPosts.filter(
  (item) => item.data?.pubDate && item.data?.title
);
const sorted = validPosts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const index = sorted.findIndex((item) => item.id === pageSlug);
const page = sorted[index];
const previous = sorted[index - 1] || null;
const next = sorted[index + 1] || null;
const { Content, headings } = await render(page);
---
<BlogLayout
  frontmatter={page.data}
  previous={previous}
  next={next}
  headings={headings}
>
  <Content />
</BlogLayout>
