---
// Props
interface Props {
  title: string;
  docs: Array<{ slug: string; title: string; order: number }>;
  index: number;
}
const { title, docs, index } = Astro.props;
const currentPath = Astro.url.pathname;
const sectionId = `section-${title.toLowerCase().replace(/\s+/g, "-")}`;
// Check if current path matches any doc or the static links
const isOpenByDefault =
  docs.some(
    (doc) =>
      currentPath === `/docs/${doc.id}` ||
      currentPath === `/docs/${doc.id}/`
  ) ||
  (title.toLowerCase() === "integrations" &&
    (currentPath === "/integrations" || currentPath === "/integrations/")) ||
  (title.toLowerCase() === "changelog" &&
    (currentPath === "/changelog" || currentPath === "/changelog/"));
---

<div class="relative" id={sectionId}>
  <div class="relative accordion-section group">
    <div
      class={`absolute inset-y-0 left-0 right-0 bg-base-50 dark:bg-white/2 rounded-md transition-all duration-300 z-0 ${
        isOpenByDefault ? "opacity-100" : "opacity-0"
      }`}
      aria-hidden="true"
      data-background
    >
    </div>
    <button
      class="relative w-full text-left px-4 py-2.5 text-xs font-medium text-base-900 dark:text-white transition-colors duration-200 focus:outline-none z-10"
      aria-expanded={isOpenByDefault}
      data-accordion-trigger
      data-fixed={index === 0}
    >
      {title}
    </button>
    <div
      class="overflow-hidden accordion-content transition-all duration-500 ease-in-out"
      style={`height: ${isOpenByDefault ? "auto" : "0"}; opacity: ${
        isOpenByDefault ? "1" : "0"
      }; transform: translateY(${isOpenByDefault ? "0" : "-0.5rem"});`}
    >
      <nav class="relative z-10 flex flex-col pb-2">
        {
          title.toLowerCase() === "integrations" && (
            <a
              href="/integrations"
              class={`block px-3 ml-4 py-2 text-xs transition-colors duration-200 ${
                currentPath === "/integrations" ||
                currentPath === "/integrations/"
                  ? "text-base-600 dark:text-base-300 font-medium"
                  : "text-base-500 dark:text-base-300 hover:text-base-600 dark:hover:text-white"
              }`}
            >
              View Integrations
            </a>
          )
        }
        {
          title.toLowerCase() === "changelog" && (
            <a
              href="/changelog"
              class={`block px-3 ml-4 py-2 text-xs transition-colors duration-200 ${
                currentPath === "/changelog" || currentPath === "/changelog/"
                  ? "text-base-600 dark:text-base-300 font-medium"
                  : "text-base-500 dark:text-base-300 hover:text-base-600 dark:hover:text-white"
              }`}
            >
              View Changelog
            </a>
          )
        }

        {
          docs.map((doc) => {
            const href = `/docs/${doc.slug}`;
            const isActive = currentPath === href || currentPath === `${href}/`;
            return (
              <a
                href={href}
                class={`block px-3 ml-4 py-2 text-xs transition-colors duration-200 border-l ${
                  isActive
                    ? "border-l-accent-500 dark:border-l-accent-500 text-base-600 dark:text-base-300 font-medium"
                    : "border-l-base-200 dark:border-l-base-700 text-base-500 dark:text-base-300 hover:text-base-600 dark:hover:text-white"
                }`}
              >
                {doc.title}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</div>
<script type="module">
  // Wait for all components to be fully rendered
  document.addEventListener("astro:page-load", () => {
    initializeAccordions();
  });

  // Also run on initial page load for non-SPA navigation
  document.addEventListener("DOMContentLoaded", () => {
    initializeAccordions();
  });

  function initializeAccordions() {
    // Small delay to ensure all components are rendered
    setTimeout(() => {
      const sections = document.querySelectorAll(".accordion-section");

      sections.forEach((section) => {
        const toggle = section.querySelector("[data-accordion-trigger]");
        const content = section.querySelector(".accordion-content");
        const background = section.querySelector("[data-background]");

        if (!toggle || !content) return;

        // Remove any existing listeners to prevent duplicates
        toggle.removeEventListener("click", handleAccordionClick);

        // Add click listener
        toggle.addEventListener("click", handleAccordionClick);

        function handleAccordionClick() {
          const isOpen = toggle.getAttribute("aria-expanded") === "true";

          // Close all other sections
          sections.forEach((s) => {
            if (s !== section) {
              const t = s.querySelector("[data-accordion-trigger]");
              const c = s.querySelector(".accordion-content");
              const b = s.querySelector("[data-background]");

              if (c && t && b) {
                c.style.height = "0";
                c.style.opacity = "0";
                c.style.transform = "translateY(-0.5rem)";
                t.setAttribute("aria-expanded", "false");
                b.classList.remove("opacity-100");
                b.classList.add("opacity-0");
              }
            }
          });

          // Toggle current section
          if (isOpen) {
            content.style.height = "0";
            content.style.opacity = "0";
            content.style.transform = "translateY(-0.5rem)";
            toggle.setAttribute("aria-expanded", "false");
            background?.classList.remove("opacity-100");
            background?.classList.add("opacity-0");
          } else {
            const scrollHeight = content.scrollHeight + "px";
            content.style.height = scrollHeight;
            content.style.opacity = "1";
            content.style.transform = "translateY(0)";
            toggle.setAttribute("aria-expanded", "true");
            background?.classList.add("opacity-100");
            background?.classList.remove("opacity-0");
          }
        }
      });
    }, 100);
  }
</script>
