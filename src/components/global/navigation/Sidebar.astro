---
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
// Assets
import Logo from "@/components/assets/Logo.astro";
// Components
import SidebarLinks from "@/components/global/navigation/SidebarLinks.astro";
// Scripts
import MobileMenuScript from "@/components/fundations/scripts/MobileMenuScript.astro";

const staticLinks = [
  { href: "/integrations", title: "Integrations" },
  { href: "/changelog", title: "Changelog" },
  { href: "/infopages/licensing", title: "Licensing" },
];

// Get all docs and group by category
import { getCollection } from "astro:content";
const allDocs = await getCollection("docs");

// Define category display names and order - ONLY include categories you want
const categoryConfig = {
  "getting-started": { name: "Getting Started", order: 1 },
  navigation: { name: "Navigaton", order: 2 },
  components: { name: "Components", order: 3 },
  shiki: { name: "Shiki", order: 4 },
  help: { name: "Help & Support", order: 5 },
};

// Group all docs first, then filter
const allGroupedDocs = allDocs.reduce(
  (acc, doc) => {
    const category = doc.data.category;
    if (!acc[category]) {
      acc[category] = [];
    }
    acc[category].push({
      slug: doc.id,
      title: doc.data.title,
      order: doc.data.order || 999,
    });
    return acc;
  },
  {} as Record<string, Array<{ slug: string; title: string; order: number }>>
);

// Filter to only include configured categories
const groupedDocs = Object.keys(allGroupedDocs)
  .filter((category) => categoryConfig[category])
  .reduce(
    (acc, category) => {
      acc[category] = allGroupedDocs[category];
      return acc;
    },
    {} as Record<string, Array<{ slug: string; title: string; order: number }>>
  );

// Sort docs within each category by order
Object.keys(groupedDocs).forEach((category) => {
  groupedDocs[category].sort((a, b) => a.order - b.order);
});

// Sort categories
const sortedCategories = Object.keys(groupedDocs).sort((a, b) => {
  const orderA = categoryConfig[a]?.order || 999;
  const orderB = categoryConfig[b]?.order || 999;
  return orderA - orderB;
});

// Get current path for active state
const currentPath = Astro.url.pathname;
---

<div
  id="sidebar-backdrop"
  class="fixed inset-0 z-40 hidden bg-base-900/50 lg:hidden"
>
</div>

<aside
  id="sidebar"
  class="fixed inset-y-0 z-50 lg:top-0 lg:left-0 bg-base-100 lg:z-50 w-72 dark:bg-base-700 transform -translate-x-full transition-transform duration-300 ease-in-out lg:translate-x-0"
>
  <div
    class="flex flex-col h-full bg-white border-r lg:ml-1 lg:border lg:rounded-tl-xl border-base-200 dark:border-base-800 lg:mt-1 dark:bg-base-900"
  >
    <div class="flex items-center justify-between px-8 h-14">
      <a
        href="/"
        class="flex items-center space-x-2 text-base-900 dark:text-white"
      >
        <Logo class="size-4" />
        <span class="text-lg font-semibold">ZeroIndex</span>
      </a>
      <button
        id="sidebar-close"
        class="p-2 lg:hidden rounded-md text-base-400 hover:text-base-500 hover:bg-base-200"
      >
        <span class="sr-only">close sidebar</span>
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <nav class="flex-1 px-4 py-6 overflow-y-auto space-y-1">
      {
        sortedCategories.map((categoryKey, index) => {
          const category = categoryConfig[categoryKey];
          const docs = groupedDocs[categoryKey];
          return (
            <SidebarLinks
              title={category?.name || categoryKey}
              docs={docs}
              index={index}
            />
          );
        })
      }
      {
        staticLinks.map((link) => {
          const isActive =
            currentPath === link.href || currentPath === `${link.href}/`;
          return (
            <a
              href={link.href}
              class={`block px-4 py-2.5 text-xs font-medium transition-colors duration-200 rounded-md ${
                isActive
                  ? "bg-base-50 dark:bg-white/2 text-accent-600 dark:text-accent-400"
                  : "text-base-700 dark:text-base-300 hover:bg-base-50 dark:hover:bg-base-800 hover:text-base-900 dark:hover:text-white"
              }`}
            >
              {link.title}
            </a>
          );
        })
      }
    </nav>

    <div
      class="relative px-6 py-4 border-t border-base-200 dark:border-base-800"
    >
      <Button
        isLink={true}
        size="sm"
        variant="muted"
        href="https://buy.polar.sh/polar_cl_MOD8VbnH7TZZ58sMoFCNmoJeM1mV2DeU53Jsw1NBrY6"
      >
        Buy ZeroIndex
      </Button>
    </div>
  </div>
</aside>

<MobileMenuScript />
