---
// Components
import SearchBar from "@/components/global/navigation/SearchBar.astro";
import ThemeToggle from "@/components/assets/ThemeToggle.astro";
const navigationButtons = [
  {
    title: "Buy Zeroindex",
    href: "https://buy.polar.sh/polar_cl_MOD8VbnH7TZZ58sMoFCNmoJeM1mV2DeU53Jsw1NBrY6",
  },
  {
    title: "Overview",
    href: "/system/overview",
  },
  {
    title: "Blog",
    href: "/blog/",
  },
  {
    title: "sign in",
    href: "/sign-in",
  },
];
---

<header
  class="fixed top-0 right-0 z-50 hidden w-auto lg:block left-72 bg-base-100 dark:bg-base-700"
>
  <div
    class="flex items-center justify-between gap-4 lg:mt-1 lg:mr-1 border-t lg:border-r lg:rounded-tr-xl px-4 py-2.5 border-b border-base-200 dark:border-base-800 bg-white dark:bg-base-900"
  >
    <div class="w-full max-w-48">
      <SearchBar searchId="desktop" />
    </div>
    <div class="flex flex-col ml-auto gap-2 md:gap-4 md:flex-row">
      {
        navigationButtons.map((Button, index) => (
          <a
            href={Button.href}
            class="text-2xl  md:text-sm hover:text-base-600 text-base-500 dark:text-base-400 dark:hover:text-base-200 transition-colors"
          >
            {Button.title}
          </a>
        ))
      }
    </div>
    <ThemeToggle />
  </div>
</header>
