---
import Dots from "@/components/assets/Dots.astro";
import Text from "@/components/fundations/elements/Text.astro";

const {
  title = "Page Title",
  description,
  class: customClass = "",
  innerClass = "",
} = Astro.props;
---

<div class={`relative ${customClass}`}>
  <div
    class={`relative flex flex-col h-full p-8 bg-white dark:bg-base-900 ${innerClass}`}
  >
    <div>
      <Text
        tag="h1"
        variant="displaySM"
        class="font-semibold text-base-900 dark:text-white"
      >
        {title}
      </Text>

      {
        description && (
          <Text
            tag="p"
            variant="textBase"
            class="max-w-xl mt-2 text-base-500  dark:text-base-300"
          >
            {description}
          </Text>
        )
      }
    </div>
    <slot />
  </div>
</div>
