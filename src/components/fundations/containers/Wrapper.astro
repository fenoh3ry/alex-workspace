---
interface Props {
  variant?: "standard" | "prose"; // Define any variants you need
  class?: string; // Optional prop for additional classes
  id?: string; // Optional prop for an id
}
const { variant = "standard", class: extraClass = "" } = Astro.props;
// Map each variant to its specific classes
const variantClasses = {
  standard:
    "mx-auto  2xl:max-w-6xl 2xl:px-12 w-full  max-w-5xl border-x border-base-200 px-4 dark:border-base-800 ",

  prose:
    "prose prose-base prose-headings:font-medium  text-base-500 dark:text-base-400 dark:text-base-400 prose-headings:text-base-900 dark:prose-headings:text-white prose-blockquote:text-base-500 dark:prose-blockquote:text-base-600 dark:text-base-400 dark:prose-blockquote:border-base-500 prose-blockquote:font-normal prose-blockquote:tracking-normal prose-img:border prose-img:border-base-200 dark:prose-img:border-base-700 dark:prose-code:text-white prose-a:text-accent-500 hover:prose-a:text-accent-500 dark:prose-hr:border-base-700 prose-hr:border-base-300 prose-pre:border-none prose-pre:rounded-xl prose-strong:font-medium prose-a:duration-200 dark:prose-strong:text-white max-w-none prose-pre:scrollbar-hide prose-pre:relative prose-headings:scroll-mt-24 prose-pre:selection:bg-accent-600/10 prose-pre:selection:text-base-900 dark:prose-pre:selection:text-white  prose-pre:outline-base-200 dark:prose-pre:outline-base-800 prose-pre:my-0 dark:prose-tr:border-base-700 dark:prose-thead:border-base-700 prose-pre:scrollbar-hide prose-pre:overflow-y-hidden",
};
// Combine the classes for the specified variant with any extra classes
const classes = `${variantClasses[variant]} ${extraClass}`.trim();
---

<div class={classes}>
  <!-- Render the default slot content -->
  <slot />
</div>
