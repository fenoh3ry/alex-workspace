---
// Icons
import ChevronDown from "@/components/fundations/icons/ChevronDown.astro";
// src/components/AccordionItem.astro
export interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<details
  id={id}
  class="border-b border-base-200 dark:border-base-800 last:border-b-0 group [&[open]>summary_svg]:rotate-180 select-none"
>
  <summary
    class="flex items-center justify-between w-full py-2 font-medium text-left cursor-pointer gap-2 focus:outline-none focus:text-accent-500 focus:ring-inset text-base-900 dark:text-white transition-colors duration-200"
  >
    {title}

    <ChevronDown size="sm" class="transition-transform duration-300" />
  </summary>
  <div class="py-2 text-base-600 dark:text-base-300">
    <slot />
  </div>
</details>
