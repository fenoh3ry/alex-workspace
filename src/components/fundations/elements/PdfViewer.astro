---
// Components
import Button from "./Button.astro";

// Props
export interface Props {
  title: string;
  description: string;
  pdfUrl: string;
  category: string;
  backUrl: string;
}

const { title, description, pdfUrl, category, backUrl } = Astro.props;
---

<section class="flex flex-col w-full h-full bg-base-50 dark:bg-base-900 rounded-xl overflow-hidden">
  <!-- Header -->
  <div class="flex flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between bg-base-100 dark:bg-base-800 border-b border-base-200 dark:border-base-700">
    <div class="flex flex-col gap-1 min-w-0">
      <!-- Category badge -->
      {category && (
        <span class="text-xs font-medium uppercase tracking-wider text-accent-600 dark:text-accent-400">
          {category}
        </span>
      )}
      <!-- Title -->
      <h1 class="text-lg font-semibold text-base-900 dark:text-white truncate">
        {title}
      </h1>
      <!-- Description -->
      {description && (
        <p class="text-sm text-base-500 dark:text-base-400 line-clamp-2">
          {description}
        </p>
      )}
    </div>

    <!-- Action buttons -->
    <div class="flex items-center gap-3 shrink-0">
      <!-- Back button -->
      <Button
        variant="muted"
        size="sm"
        href={backUrl}
        isLink={true}
      >
        <span slot="left-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path d="M15 6l-6 6l6 6"></path>
          </svg>
        </span>
        Retour
      </Button>

      <!-- Download button -->
      <Button
        variant="default"
        size="sm"
        href={pdfUrl}
        download
        isLink={true}
      >
        <span slot="left-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path d="M21 15v4a2 2 0 0 1 -2 2H5a2 2 0 0 1 -2 -2v-4"></path>
            <path d="M7 10l5 5l5 -5"></path>
            <path d="M12 15V3"></path>
          </svg>
        </span>
        Télécharger
      </Button>
    </div>
  </div>

  <!-- PDF Viewer -->
  <div class="flex-1 w-full bg-white dark:bg-base-950" style="min-height: 90vh;">
    <object
      data={pdfUrl}
      type="application/pdf"
      class="w-full h-full"
      style="min-height: 90vh;"
    >
      <div class="flex flex-col items-center justify-center gap-4 p-12 text-center" style="min-height: 90vh;">
        <p class="text-base-600 dark:text-base-400 text-base">
          Votre navigateur ne peut pas afficher ce PDF directement.
        </p>
        <Button
          variant="accent"
          size="base"
          href={pdfUrl}
          download
          isLink={true}
        >
          <span slot="left-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
              <path d="M21 15v4a2 2 0 0 1 -2 2H5a2 2 0 0 1 -2 -2v-4"></path>
              <path d="M7 10l5 5l5 -5"></path>
              <path d="M12 15V3"></path>
            </svg>
          </span>
          Télécharger le PDF
        </Button>
      </div>
    </object>
  </div>
</section>
