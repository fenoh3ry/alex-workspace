---
import Text from "@/components/fundations/elements/Text.astro";
// Icons
import ChevronRight from "@/components/fundations/icons/ChevronRight.astro";
const features = [
  {
    title: "Droit international privé",
    description: "Méthode savignienne, arrêts Bartholo et Wagons-Lits, cours Clavel, DIP malagasy",
    href: "/docs/droit-international-prive/methode-savignienne",
  },
  {
    title: "Droit du commerce international",
    description: "Fiches synthétiques DCI, Mémento DALLOZ complet",
    href: "/docs/droit-commerce-international/fiche-synthetique-dci",
    cta: "Voir les fiches ",
  },
  {
    title: "Sociologie politique",
    description: "Synthèses Braud — chapitre 12, élaboration du discours scientifique",
    href: "/docs/sociologie-politique/synthese-chap12-section1",
    cta: "Lire les synthèses ",
  },
  {
    title: "Sujet minier",
    description: "Gouvernance minière, EITI, audits QMM, pollution Madena et Rio Tinto",
    href: "/docs/sujet-minier/analyse-croisee-gouvernance-miniere-madagascar",
    cta: "Explorer ",
  },
];
---

<section>
  <div class="px-8 py-12">
    <div class="max-w-2xl">
      <Text
        tag="h2"
        id="get-started-heading"
        variant="textLG"
        class="mt-auto font-medium text-base-900 dark:text-white"
      >
        Matières
      </Text>
      <Text
        tag="p"
        variant="textSM"
        class="mt-4 text-base-500 dark:text-base-300 leading-6 text-pretty"
      >
        Tous les documents et fiches de cours organisés par matière. Cliquez sur une matière pour accéder au contenu complet.
      </Text>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        features.map((feature) => {
          return (
            <div class="flex flex-col justify-between h-full">
              <div>
                <Text
                  tag="h3"
                  variant="textBase"
                  class="font-medium text-base-900 dark:text-white"
                >
                  {feature.title}
                </Text>
                <Text
                  tag="p"
                  variant="textSM"
                  class="mt-2 text-base-600 dark:text-base-400 text-pretty"
                >
                  {feature.description}
                </Text>
              </div>
              <a
                href={feature.href}
                class="flex items-center mt-8 text-sm text-accent-600 hover:text-accent-500 dark:text-accent-400 gap-2 group"
                aria-label={`${feature.title}: ${feature.description}`}
              >
                {feature.cta || "Lire "}
                <ChevronRight
                  size="sm"
                  class="group-hover:translate-x-2 duration-300"
                />
              </a>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
