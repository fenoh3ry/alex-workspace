---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Icons
import ChevronRight from "@/components/fundations/icons/ChevronRight.astro";

const resources = [
  {
    id: "dev",
    title: "Développement",
    description:
      "Prototypes et synthèses réglementation STN (stratégie nationale de transformation).",
    href: "/docs/developpement/prototype-A-reglementation-stn",
  },
  {
    id: "culture",
    title: "Culture",
    description:
      "Approche culturelle en politique comparée — sources et analyses.",
    href: "/docs/culture/sources-culturelles",
  },
  {
    id: "dip-malagasy",
    title: "DIP Malagasy",
    description:
      "Droit international privé malagasy — cours et extraits.",
    href: "/docs/droit-international-prive/dip-malagasy",
  },
  {
    id: "eiti",
    title: "EITI Madagascar",
    description: "Rapports EITI et audits liés à la gouvernance minière.",
    href: "/docs/sujet-minier/eiti-rapport-assoupli-2019-2020",
  },
];
---

<section>
  <div class="px-8 py-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    <div>
      <Text
        tag="h2"
        id="resources-heading"
        variant="textLG"
        class="mt-auto font-medium text-base-900 dark:text-white"
      >
        Autres ressources
      </Text>
      <Text
        tag="p"
        variant="textSM"
        class="mt-4 text-base-500 dark:text-base-300 leading-6 text-balance"
      >
        Documents complémentaires — développements, culture, sources primaires et rapports EITI.
      </Text>
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-2 lg:col-span-2"
    >
      {
        resources.map((item) => (
          <div class="relative flex flex-col justify-between h-full p-6 bg-base-50 dark:bg-white/2 gap-8 rounded-xl">
            <div>
              <Text
                tag="h3"
                variant="textBase"
                class="font-medium text-base-900 dark:text-white"
              >
                {item.title}
              </Text>
              <Text tag="p" variant="textSM" class="mt-2 text-base-500 dark:text-base-400">
                {item.description}
              </Text>
            </div>
            <a
              href={item.href}
              class="flex items-center text-sm  text-accent-600 hover:text-accent-500 dark:text-accent-400 gap-2 group"
              aria-label={`${item.title}: ${item.description}`}
            >
              Explorer
              <ChevronRight
                size="sm"
                class="group-hover:translate-x-2 duration-300"
              />
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
