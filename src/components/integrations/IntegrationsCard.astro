---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Icons
import ChevronRight from "@/components/fundations/icons/ChevronRight.astro";
// Content
const { integration, description, url, logo } = {
  url: "/integrations/" + Astro.props.post.id,
  integration: Astro.props.post.data.integration,
  description: Astro.props.post.data.description,
  logo: Astro.props.post.data.logo.url,
};
---
<div
  class="relative flex flex-col justify-between h-full p-6 bg-base-50 dark:bg-white/2 rounded-xl"
>
  <Image src={logo} alt={integration} width={300} height={300} class="size-8" />
  <Text
    tag="h3"
    variant="textBase"
    class="mt-8 font-medium text-base-900 dark:text-white"
  >
    {integration}
  </Text>
  <Text tag="p" variant="textSM" class="mt-2 text-base-500 dark:text-base-400">
    {description}
  </Text>
  <a
    href={url}
    title={`View details for ${integration}`}
    aria-label={`View details for ${integration}`}
    class="flex items-center mt-8 text-sm text-accent-600 hover:text-accent-500 dark:text-accent-400 gap-2 group"
  >
    View Details <ChevronRight
      size="sm"
      class="group-hover:translate-x-2 duration-300"
    /></a
  >
</div>
